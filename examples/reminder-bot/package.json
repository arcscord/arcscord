{
  "name": "reminder-bot",
  "version": "1.0.0",
  "description": "A user-install reminder bot example made with Arcscord",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "start": "node --import=tsx --env-file-if-exists=.env src/index.ts",
    "dev": "node --import=tsx --env-file-if-exists=.env src/index.ts dev debug",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "arcscord": "1.0.0-next.1",
    "better-sqlite3": "^12.5.0",
    "discord.js": "^14.26.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=24.11.0"
  }
}
