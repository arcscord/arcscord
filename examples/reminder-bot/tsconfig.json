{
  "compilerOptions": {
    "target": "es2022",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "paths": {
      "#/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "strict": true,
    "outDir": "./out",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "out"]
}
