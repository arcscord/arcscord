{
  "name": "starter-bot",
  "version": "1.0.0",
  "description": "A discord bot made with arcscord",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env -r @swc-node/register -r tsconfig-paths/register src/index.ts",
    "dev": "node --env-file-if-exists=.env -r @swc-node/register -r tsconfig-paths/register src/index.ts dev debug",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "arcscord": "1.0.0-next.1",
    "discord.js": "^14.26.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@swc-node/core": "^1.14.1",
    "@swc-node/register": "^1.11.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
