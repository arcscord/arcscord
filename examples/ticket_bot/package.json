{
  "name": "ticket_bot",
  "version": "1.0.0",
  "packageManager": "pnpm@11.8.0",
  "description": "A discord bot made with arcscord",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env -r @swc-node/register -r tsconfig-paths/register src/index.ts",
    "dev": "npx nodemon --exec \"node --env-file-if-exists=.env -r @swc-node/register -r tsconfig-paths/register src/index.ts\" dev debug",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@arcscord/middleware": "^1.0.0-next.0",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "arcscord": "1.0.0-next.1",
    "discord.js": "^14.26.4",
    "dotenv": "^17.2.3",
    "i18next": "^26.3.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@swc-node/core": "^1.14.1",
    "@swc-node/register": "^1.11.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
