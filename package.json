{
  "name": "@arcscord/arcscord",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "clean:full": "node scripts/clean-full.mjs",
    "build": "pnpm build:all && pnpm build:arcscord && pnpm build:middleware",
    "build:all": "pnpm -r --filter='./packages/*' --filter='!./packages/{arcscord,middleware}' run build",
    "build:arcscord": "pnpm -r --filter='./packages/arcscord' run build",
    "build:middleware": "pnpm -r --filter='./packages/middleware' run build",
    "lint": "node scripts/lint.mjs",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "node scripts/test.mjs",
    "test:test-bot": "pnpm -r --filter '@arcscord/test-bot' run start",
    "test:test-bot:bun": "pnpm --filter @arcscord/test-bot run start:bun",
    "pack:local": "node scripts/pack-local.mjs",
    "test:bun": "pnpm pack:local && cd test/compat/bun-consumer && bun install --no-save && bun run typecheck && bun run smoke && bun test",
    "test:typescript-compat": "pnpm pack:local && cd test/compat/typescript-consumer && pnpm install --no-lockfile && pnpm typecheck",
    "test:node-compat": "pnpm pack:local && cd test/compat/node-consumer && pnpm install --no-lockfile && pnpm smoke:esm && pnpm smoke:cjs",
    "docs:api": "node scripts/generate-api-docs.mjs --channel dev",
    "docs:api:release": "node scripts/generate-api-docs.mjs --channel release",
    "docs:build": "pnpm docs:api && pnpm --filter @arcscord/website build",
    "docs:start": "pnpm docs:api && pnpm --filter @arcscord/website start",
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/node": "^24.10.0",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "only-allow": "^1.2.2",
    "tsdown": "0.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcscord/arcscord.git"
  },
  "engines": {
    "node": ">=24.11.0",
    "bun": ">=1.3.0",
    "npm": ">=9.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*": "eslint --fix --no-warn-ignored"
  },
  "packageManager": "pnpm@11.8.0"
}
