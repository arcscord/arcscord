{
  "i18n": {
    "command": {
      "name": "i18n-en",
      "description": "test of i18n",
      "run": "Reply in english for {{topic}} !"
    },
    "autocomplete": {
      "option": {
        "name": "topic",
        "description": "Topic to test with localized autocomplete"
      },
      "choices": {
        "command": "Command",
        "component": "Component",
        "autocomplete": "Autocomplete"
      }
    },
    "component": {
      "run": "Localized component reply in english !"
    }
  },
  "componentsV2": {
    "i18n": {
      "support": {
        "title": "Support",
        "description": "Open a localized support ticket."
      },
      "bug": {
        "title": "Bug",
        "description": "Report a localized bug."
      }
    }
  },
  "middleware": {
    "cooldown": "Wait {{seconds}}s before using this command again.",
    "command": {
      "allowList": "You are not allowed to use this command.",
      "botPermission": "I am missing command permissions: {{permissions}}.",
      "ok": "Command middleware passed."
    },
    "component": {
      "allowList": "You are not allowed to use this component.",
      "authorOnly": "Only the original user can use this component.",
      "botPermission": "I am missing component permissions: {{permissions}}.",
      "memberPermission": "You are missing component permissions: {{permissions}}.",
      "ok": "Component middleware passed."
    }
  }
}
