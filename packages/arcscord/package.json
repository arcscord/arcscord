{
  "name": "arcscord",
  "version": "0.3.0-beta-8",
  "description": "A discord.js framework, slash command first and full typescript !",
  "author": "Arcoz0308",
  "license": "MIT",
  "homepage": "https://github.com/arcscord/arcscord#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcscord/arcscord.git"
  },
  "bugs": {
    "url": "https://github.com/arcscord/arcscord/issues"
  },
  "keywords": [
    "discord",
    "framework",
    "discord.js",
    "arcscord",
    "typescript",
    "slash-commands",
    "typed-commands"
  ],
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/esm/index.d.mts",
      "default": "./dist/esm/index.mjs"
    },
    "require": {
      "types": "./dist/cjs/index.d.ts",
      "default": "./dist/cjs/index.cjs"
    }
  },
  "imports": {
    "#/*": "./dist/*.js"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsup",
    "typecheck": "tsc -b src",
    "docs": "typedoc"
  },
  "dependencies": {
    "@arcscord/better-error": "^1.0.4",
    "@arcscord/error": "^2.0.1",
    "cron": "^4.4.0",
    "dayjs": "^1.11.20",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.26.3",
    "i18next": "^26.0.8",
    "tintify": "^1.1.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@swc-node/core": "^1.14.1",
    "@swc-node/register": "^1.11.1",
    "@types/node": "^25.6.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "vite": "8.0.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist/"
  ]
}
