{
  "name": "arcscord",
  "version": "1.0.0-next.3",
  "description": "A discord.js framework, slash command first and full typescript !",
  "author": "Arcoz0308",
  "license": "MIT",
  "homepage": "https://arcscord.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcscord/arcscord.git"
  },
  "bugs": {
    "url": "https://github.com/arcscord/arcscord/issues"
  },
  "keywords": [
    "discord",
    "framework",
    "discord.js",
    "arcscord",
    "typescript",
    "slash-commands",
    "typed-commands"
  ],
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/esm/testing/index.d.mts",
        "default": "./dist/esm/testing/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/testing/index.d.ts",
        "default": "./dist/cjs/testing/index.cjs"
      }
    }
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.eslint.json",
    "docs": "typedoc"
  },
  "dependencies": {
    "@arcscord/error": "workspace:^",
    "discord-api-types": "^0.38.49",
    "discord.js": "^14.26.4",
    "i18next": "^26.3.3"
  },
  "peerDependencies": {
    "typescript": ">=5.4.0",
    "discord.js": ">=14.26.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsdown": "0.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist/cjs/",
    "dist/esm/"
  ]
}
