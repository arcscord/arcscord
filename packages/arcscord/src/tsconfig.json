{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "outDir": "../dist",
    "incremental": false,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "#/*": ["./*"]
    }
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.no.test.ts",
    "**/_test/**"
  ]
}
