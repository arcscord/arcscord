{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "incremental": false,
    "declarationMap": false,
    "declaration": false,
    "types": ["node"]
  },
  "include": [
    "src/**/*" // Only include files in the src directory
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.mts",
    "src/**/_test/**"
  ]
}
