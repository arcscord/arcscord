{
  "name": "@arcscord/cli",
  "version": "1.0.0",
  "private": true,
  "description": "Abandoned internal Arcscord CLI prototype",
  "author": "Arcoz0308",
  "license": "MIT",
  "homepage": "https://arcscord.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcscord/arcscord.git"
  },
  "bugs": {
    "url": "https://github.com/arcscord/arcscord/issues"
  },
  "keywords": [
    "arcscord",
    "cli",
    "discord",
    "command"
  ],
  "main": "dist/index.js",
  "bin": {
    "arcscord": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run fix:babel",
    "typecheck": "tsc -p tsconfig.eslint.json",
    "test": "vitest run",
    "fix:babel": "node -e \"const fs = require('fs'); const path = './dist/utils/esm.js'; let data = fs.readFileSync(path, 'utf8'); let updatedContent = data.replace('traverse;', 'traverse.default;').replace('generate;', 'generate.default;'); fs.writeFileSync(path, updatedContent, 'utf8'); console.log('File updated successfully.');\""
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^26.0.1",
    "i18next": "^26.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@arcscord/error": "workspace:^",
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@commander-js/extra-typings": "^15.0.0",
    "@inquirer/prompts": "^8.5.2",
    "arcscord": "workspace:^",
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "type": "module",
  "files": [
    "dist/",
    "templates/"
  ]
}
