{
  "name": "@arcscord/better-error",
  "version": "1.0.5",
  "description": "A better error class",
  "author": "Arcoz0308",
  "license": "MIT",
  "homepage": "https://arcscord.dev/packages/better-error",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcscord/arcscord.git"
  },
  "bugs": {
    "url": "https://github.com/arcscord/arcscord/issues"
  },
  "keywords": [
    "arcscord",
    "error",
    "bettererror"
  ],
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/esm/index.d.mts",
      "default": "./dist/esm/index.mjs"
    },
    "require": {
      "types": "./dist/cjs/index.d.ts",
      "default": "./dist/cjs/index.cjs"
    }
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.eslint.json",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist/cjs/",
    "dist/esm/"
  ]
}
