{
  "name": "@arcscord/middleware",
  "version": "0.5.1",
  "description": "Middleware for arcscord",
  "author": "Arcoz0308",
  "license": "MIT",
  "homepage": "https://arcscord.dev/packages/middleware",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcscord/arcscord.git"
  },
  "bugs": {
    "url": "https://github.com/arcscord/arcscord/issues"
  },
  "keywords": [
    "arcscord",
    "discord",
    "middleware"
  ],
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/esm/index.d.mts",
      "default": "./dist/esm/index.mjs"
    },
    "require": {
      "types": "./dist/cjs/index.d.ts",
      "default": "./dist/cjs/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.eslint.json",
    "docs": "typedoc"
  },
  "dependencies": {
    "arcscord": "workspace:^"
  },
  "peerDependencies": {
    "discord.js": "^14.26.4",
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "discord.js": "^14.26.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist/cjs/",
    "dist/esm/"
  ]
}
